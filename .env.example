# Model configuration for adversarial attack experiments.
# Copy this file to .env and fill in your values.
# Variables here are loaded automatically by all run scripts and by Inspect AI.
# Override any value at runtime with -T flags on the inspect eval command.

# ---------------------------------------------------------------------------
# TARGET MODEL — generates the buggy code (Step 1)
# ---------------------------------------------------------------------------
MODEL=ollama/llama3.1:8b
# Alternatives: ollama/tulu3.1:8b  |  ollama/olmo2:7b

# ---------------------------------------------------------------------------
# JUDGE MODEL — evaluates the adversarial attack (Step 4)
# Must be STRONGER than the target to produce a meaningful ASR signal.
#
# Recommended (local, no API key): ollama/qwen2.5-coder:7b
#   Pull with: ollama pull qwen2.5-coder:7b
#   POC result (50 samples, MBPP, random policy, one_shot):
#     baseline ASR (no tactic) = 2%   ← judge resists raw buggy code
#     random tactic ASR        = 34%  ← tactics meaningfully increase success
#   Requires ~5 GB VRAM alongside the target model (~10 GB total).
# ---------------------------------------------------------------------------
JUDGE_MODEL=ollama/qwen2.5-coder:7b

# Cloud API alternatives (stronger but require keys):
#   Groq free tier:  JUDGE_MODEL=groq/llama-3.3-70b-versatile  + GROQ_API_KEY=gsk_...
#   OpenAI:          JUDGE_MODEL=openai/gpt-4o-mini             + OPENAI_API_KEY=sk_...

# ---------------------------------------------------------------------------
# SELECTOR MODEL — picks the adversarial tactic (agent_based_decision only)
# Keep equal to target model unless you have a specific reason to change it.
# ---------------------------------------------------------------------------
SELECTOR_MODEL=ollama/llama3.1:8b
